# local-quality – lokal Playwright (egen resetbar database i backend)
APP_ENV=local-quality
APP_DEBUG=true
APP_NAME=Bifrost
APP_BASE_URL=http://jaktfeltcup.local

BACKEND_API_URL=http://api.bifrost.local
BACKEND_PATH=../bifrost-backend
BACKEND_DOTENV=.env.local-quality

EVENTS_URL=http://admin.bifrost.local

MAIL_MODE=off
PAYMENT_MODE=off
ALLOW_WRITES=true
ROBOTS_MODE=noindex
QUALITY_RESET_DATABASE=true
QUALITY_SEED_DATABASE=true
