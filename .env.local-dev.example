# local-dev – daglig utvikling (ikke reset automatisk)
APP_ENV=local-dev
APP_DEBUG=true
APP_NAME=Bifrost
APP_BASE_URL=http://jaktfeltcup.local

BACKEND_API_URL=http://api.bifrost.local
BACKEND_PATH=../bifrost-backend
BACKEND_DOTENV=.env

# V3 Events API (public calendar/context). Defaults to admin.* derived from BACKEND_API_URL.
EVENTS_URL=http://admin.bifrost.local

# V3 Admin Core auth (optional; defaults to EVENTS_URL / admin.*)
ADMIN_URL=http://admin.bifrost.local

MAIL_MODE=log
PAYMENT_MODE=off
ALLOW_WRITES=true
ROBOTS_MODE=noindex
QUALITY_RESET_DATABASE=false
QUALITY_SEED_DATABASE=false
