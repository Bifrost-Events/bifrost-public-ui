# local-dev – daglig utvikling (ikke reset automatisk)
APP_ENV=local-dev
APP_DEBUG=true
APP_NAME=Bifrost
APP_BASE_URL=http://jaktfeltcup.local

EVENTS_URL=http://admin.bifrost.local
ADMIN_URL=http://admin.bifrost.local

ADMIN_CORE_PATH=../bifrost-admin-core
